# dadtool workspace environment — copy to .env and fill in YOUR paths.
# This file is git-ignored; .env.example is committed as a template.
#
# These are machine-specific workspace paths used by AGENTS.md and local tooling.
# The runtime config (game paths, API keys) lives in dad_config.json instead.

# Workspace directories
DAD_WORKING_DIR=F:\path\to\dadtool-importer
DAD_SISTER_REPO=F:\path\to\marquee-hud-repo\disco-tracker
DAD_DEPLOYED_MOD=D:\SteamLibrary\steamapps\common\Dead as Disco\Pagoda\Binaries\Win64\ue4ss\Mods\Marquee\Scripts

# GitHub CLI (if not on PATH)
GH_CLI_PATH=C:\Program Files\GitHub CLI\gh.exe
